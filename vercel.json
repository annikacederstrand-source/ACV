{
  "framework": null,
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/rapid-dashboard", "destination": "/rapid-dashboard.html" },
    { "source": "/rapid-new-project", "destination": "/rapid-new-project.html" },
    { "source": "/", "destination": "/rapid-dashboard.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ]
}
